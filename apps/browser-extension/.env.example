# Google Calendar integration (optional)
#
# Chrome-Extension OAuth client id used by chrome.identity.getAuthToken to read
# the user's primary calendar (calendar.readonly). The client id is public — it
# ships inside the manifest — so it is not a secret, but it is build-specific.
# Leave it empty to ship without the live integration: an un-provisioned build
# hides the calendar companion entirely (there is no sample/preview data). See
# GOOGLE_CALENDAR.md for how to mint this in Google Cloud.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Calendar dev preview (dev server only).
#
# The Vite dev server has no chrome.identity, so the calendar can't actually
# connect there — by default the companion is hidden so dev mirrors the shipped
# build. Set this to "true" to render the companion for layout review (Connect
# will still report it's unavailable). Ignored in production builds, which key
# off the manifest client id above.
VITE_CALENDAR_PREVIEW=

# Cloud sync: "Sign in with Google" (optional)
#
# Chrome-Extension OAuth client id used by chrome.identity.launchWebAuthFlow to
# get a Google ID token for the cloud-sync enable flow. This is a separate
# Web-application-type OAuth client from the calendar one above (see
# GOOGLE_CALENDAR.md) — do not reuse it. The client id is public — it ships
# inside the built page — so it is not a secret. Leave it empty to hide the
# Google sign-in button.
VITE_GOOGLE_SYNC_CLIENT_ID=

# Cloud-sync API base URL. Setting it enables the Cloud Sync settings section and points the
# client at that backend (e.g. https://api.cuewise.app, or http://localhost:8787 for a local
# `wrangler dev`). Leave empty to ship with cloud sync hidden.
VITE_SYNC_API_BASE_URL=

# Pinned extension key (base64 public key) — LOCAL builds only.
#
# Forces an unpacked build to take the same extension ID as the Web Store item,
# so chrome.identity OAuth (bound to that ID) works in dev instead of failing
# with "bad client id". Set this only in your local .env; NEVER set it in the
# release build — the published manifest must omit `key` so the Web Store manages
# the published ID. See GOOGLE_CALENDAR.md ("Stable local ID") for how to obtain
# the value.
VITE_EXTENSION_KEY=

# Local player origin override — verification builds only.
#
# Points the YouTube player iframe (and its postMessage allowlist) at a locally
# served player instead of https://cuewise.app, and extends the manifest's
# frame-src to match, so you can verify the player's CSP against this real
# client before deploying. Leave empty for every normal build. See
# apps/macos/README.md ("Verifying the player CSP") for the full recipe.
VITE_PLAYER_ORIGIN=
