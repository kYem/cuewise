{
  "name": "@cuewise/browser-extension",
  "version": "1.17.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:store": "pnpm build && pnpm package",
    "package": "node scripts/build-store-zip.js",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@cuewise/app": "workspace:*",
