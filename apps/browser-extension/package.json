    "@cuewise/sync-engine": "workspace:*",
    "@cuewise/ui": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tombcato/smart-ticker": "^1.0.4",
    "chrono-node": "^2.9.0",
    "date-fns": "catalog:",
    "lottie-web": "^5.13.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "catalog:",
