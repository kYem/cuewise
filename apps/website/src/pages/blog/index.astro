---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Blog - Cuewise"
  description="Notes from building Cuewise — security, craft, and the occasional fix we found along the way."
>
  <main>

    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow">
          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>
          </svg>
          Blog
        </div>
        <h1>Blog</h1>
        <p class="hero-sub">Notes from building Cuewise — security, craft, and the occasional fix we found along the way.</p>
      </div>
    </section>

    <section class="section-pad">
      <div class="wrap">
        <a class="content-card glass reveal post-link" href="/blog/securing-cuewise-releases/">
          <p class="post-date">June 15, 2026</p>
          <h2>How We Secure Cuewise's Releases</h2>
          <p>Cuewise auto-updates in your browser. Here's how we make sure every update is exactly the code we reviewed and built — locked down, and cryptographically signed.</p>
          <span class="read-more">Read post →</span>
        </a>
      </div>
    </section>

  </main>
</Base>

<style>
  .post-link {
    display: block;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-link:hover {
    transform: translateY(-2px);
  }

  .post-date {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 6px;
  }

  .read-more {
    display: inline-block;
    margin-top: 6px;
    font-weight: 600;
    color: #fff;
  }
</style>
