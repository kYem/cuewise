<div class="newsletter">
  <p class="newsletter-label">
    <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    Get launch updates and productivity tips
  </p>
  <form data-newsletter-form novalidate>
    <div class="newsletter-row">
      <input type="email" name="email" placeholder="Enter your email" required aria-label="Email address" />
      <input class="hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <button class="btn btn-primary" type="submit">Subscribe</button>
    </div>
    <p class="newsletter-msg" role="status" aria-live="polite"></p>
  </form>
</div>

<!-- Static file (not Astro-bundled) so CSP script-src stays 'self' with no hashes. -->
<script src="/scripts/newsletter-form.js" is:inline></script>
