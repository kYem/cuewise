---
import { SITE } from '../lib/site';
---

<header class="hero" id="top">
  <div class="wrap">
    <span class="eyebrow">
      <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/></svg>
      Your daily dose of productivity
    </span>
    <h1 class="hero-title">Turn every new tab into a <span class="accent">meaningful moment</span></h1>
    <p class="hero-sub">
      Cuewise meets you on every new tab with a hand-picked quote, your focus for the day, and a calm
      Pomodoro timer. Wisdom, intention, and momentum — without the overwhelm.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary btn-lg" href={SITE.storeUrl} target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
        Add to Chrome — Free
      </a>
      <a class="btn btn-ghost btn-lg" href="#showcase">See it in action</a>
    </div>
    <div class="trust">
      <span class="trust-pill"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Free forever</span>
      <span class="trust-pill"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Privacy-first — all local</span>
      <span class="trust-pill"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg> 2-minute setup</span>
    </div>
    <div class="hero-shot">
      <div class="hero-glow"></div>
      <div class="browser">
        <div class="browser-bar">
          <div class="dots"><span class="r"></span><span class="y"></span><span class="g"></span></div>
          <div class="url"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> New Tab</div>
        </div>
        <img src="/images/focus.png" alt="Cuewise Focus Mode — one goal, a calm timer, and a daily photo" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </div>
</header>
