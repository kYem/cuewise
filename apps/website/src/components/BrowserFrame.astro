---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  label: string;
}

const { src, alt, label } = Astro.props;
const opt = await getImage({ src, format: 'webp' });
---

<div class="browser">
  <div class="browser-bar">
    <div class="dots"><span class="r"></span><span class="y"></span><span class="g"></span></div>
    <div class="url">{label}</div>
  </div>
  <img src={opt.src} alt={alt} loading="lazy" />
</div>
